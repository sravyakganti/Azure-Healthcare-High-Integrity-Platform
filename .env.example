# =============================================================================
# .env.example
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to source control — it contains secrets.
# =============================================================================

# ---------------------------------------------------------------------------
# Azure Storage (ADLS Gen2)
# ---------------------------------------------------------------------------
AZURE_STORAGE_ACCOUNT_NAME=yourstorageaccountname
AZURE_STORAGE_ACCOUNT_KEY=your_base64_encoded_storage_account_key_here==

# ---------------------------------------------------------------------------
# Azure Active Directory — Service Principal
# Used when AZURE_STORAGE_ACCOUNT_KEY is not provided (preferred for prod)
# ---------------------------------------------------------------------------
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=yyyyyyyy-yyyy-yyyy-yyyy-yyyyyyyyyyyy
AZURE_CLIENT_SECRET=your_service_principal_client_secret_here

# ---------------------------------------------------------------------------
# ADLS Container names (override defaults if needed)
# ---------------------------------------------------------------------------
RAW_CONTAINER=raw
BRONZE_CONTAINER=bronze
SILVER_CONTAINER=silver
GOLD_CONTAINER=gold

# ---------------------------------------------------------------------------
# Local filesystem paths (override defaults if needed)
# ---------------------------------------------------------------------------
# LOCAL_DATA_PATH=/absolute/path/to/data/raw
# LOCAL_BRONZE_PATH=/absolute/path/to/data/bronze
# LOCAL_SILVER_PATH=/absolute/path/to/data/silver
# LOCAL_GOLD_PATH=/absolute/path/to/data/gold

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Pipeline tuning
# ---------------------------------------------------------------------------
BATCH_SIZE=10000
MAX_VALIDATION_ERRORS=100
