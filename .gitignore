# =============================================================================
# Azure Healthcare Data Platform — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Terraform — never commit state, secrets, or provider locks to Git
# -----------------------------------------------------------------------------
*.tfstate
*.tfstate.backup
*.tfvars
.terraform/
.terraform.lock.hcl
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# -----------------------------------------------------------------------------
# Environment & secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Large / raw data — only samples belong in Git
# -----------------------------------------------------------------------------
data/raw/
data/bronze/
data/silver/
data/gold/

# -----------------------------------------------------------------------------
# Logs & pipeline reports
# -----------------------------------------------------------------------------
logs/
pipeline/reports/
src/pipeline/reports/

# -----------------------------------------------------------------------------
# Python artefacts
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# -----------------------------------------------------------------------------
# OS / editor noise
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.iml
